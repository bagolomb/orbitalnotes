FROM node:18-alpine

WORKDIR /app

# Copy only package files first to cache install step
COPY package*.json ./

# Install deps
RUN npm install

# Copy remaining source code
COPY . .

# Expose the dev server port
EXPOSE 5173

# Run in development mode
CMD ["npm", "run", "dev", "--", "--host"]

# For production builds, replace CMD with:
# CMD ["npm", "run", "build"]
